{
    "luci-app-adguardhome-dashboard": {
        "description": "AdGuard Home Dashboard Access",
        "read": {
            "ubus": {
                "luci": [
                    "getBoardJSON",
                    "getInitList"
                ]
            },
            "file": {
                "/etc/adguardhome-dashboard.version": [ "read" ]
            }
        },
        "write": {
            "file": {
                "/etc/adguardhome-dashboard.version": [ "write" ]
            }
        }
    }
}
